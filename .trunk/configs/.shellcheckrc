enable=all
source-path=SCRIPTDIR

# SC2154: Variable referenced but not assigned — suppressed because many variables
# are injected by Trunk's own environment or defined in shell profile files that
# ShellCheck cannot see at lint time.
disable=SC2154

# SC1091: Not following sourced files — dynamic sourcing pattern used throughout.
# See repo-root .shellcheckrc for full rationale.
disable=SC1091

# SC1090: ShellCheck can't follow non-constant source — same dynamic-sourcing
# policy as SC1091. See repo-root .shellcheckrc for full rationale.
disable=SC1090

# SC2155 and SC2145 are correctness issues, not style warnings:
#   SC2155 — Declaring and assigning local var=$(cmd) in one step masks the
#             command's exit code; use separate declare + assign.
#   SC2145 — Mixing "$*"/"$@" in arithmetic expansions can corrupt argument lists.
# ShellCheck .shellcheckrc does not support per-code severity overrides, so these
# cannot be elevated to error-level here. Instead, use `make lint-errors` as an
# explicit regression gate — it runs `shellcheck --include=SC2155,SC2145` and
# exits non-zero if any violations are found. Run this in CI or pre-merge checks.
