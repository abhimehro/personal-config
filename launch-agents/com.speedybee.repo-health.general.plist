        <string>/bin/bash</string>
        <string>/Users/speedybee/dev/personal-config/scripts/run-repo-health-general.sh</string>
    </array>
    <key>StandardOutPath</key>
    <string>/Users/speedybee/Library/Logs/maintenance/repo_health_general.out</string>
