# Media Server Credentials
# Optional fallback only: copy this file to ~/.config/media-server/credentials only if you intentionally need file-based media credentials instead of the default 1Password-backed runtime.

# Align example keys with media-server-daemon.sh (MEDIA_WEBDAV_* aliases)
MEDIA_WEBDAV_USER="infuse"
MEDIA_WEBDAV_PASS="replace_with_secure_password"
