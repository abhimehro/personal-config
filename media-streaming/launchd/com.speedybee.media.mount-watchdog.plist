<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.speedybee.media.mount-watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/speedybee/dev/personal-config/media-streaming/scripts/check-stale-mounts.sh</string>
        <string>--fix</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>StandardOutPath</key>
    <string>/Users/speedybee/Library/Logs/stale-mount-watchdog.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/speedybee/Library/Logs/stale-mount-watchdog-error.log</string>
</dict>
</plist>
