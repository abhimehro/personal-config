/.gitignore text eol=lf

.github/workflows/*.lock.yml linguist-generated=true merge=ours

# Git LFS configuration for large files
# This file tells Git LFS which file patterns to track

# Large configuration files
configs/Raycast_*.rayconfig filter=lfs diff=lfs merge=lfs -text

# Patch files
*.patch filter=lfs diff=lfs merge=lfs -text

# Binary files that might be large
*.bin filter=lfs diff=lfs merge=lfs -text
*.dat filter=lfs diff=lfs merge=lfs -text

# Archive files
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# Database files
*.db filter=lfs diff=lfs merge=lfs -text
*.sqlite filter=lfs diff=lfs merge=lfs -text