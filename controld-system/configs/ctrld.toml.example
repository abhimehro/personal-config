# Control D Configuration - System Level
# Hardened for network resilience
# This file should be deployed to /etc/controld/ctrld.toml

[listener]
  [listener.0]
    ip = '127.0.0.1'
    port = 53

    [listener.0.policy]
      name = 'System Policy'
      rules = [
        { 'captive.apple.com' = [] },
        { 'detectportal.firefox.com' = [] },
        { 'neverssl.com' = [] },
        { 'p.controld.com' = [] },
        { 'local.adguard.org' = [] }
      ]

[network]
  [network.0]
    name = 'System Network'
    cidrs = ['0.0.0.0/0']

[upstream]
  [upstream.0]
    name = 'Control D System'
    type = 'doh3'
    endpoint = 'https://dns.controld.com/free'
    bootstrap_ip = '76.76.2.0'
    timeout = 3000
