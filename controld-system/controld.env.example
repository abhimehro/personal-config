# Control D Configuration
# Security Note: This file contains sensitive IDs.
# Permissions should be set to 600 (root:wheel on macOS) to prevent unauthorized access.

# Absolute path to personal-config checkout (required when controld-manager
# is installed to /usr/local/bin so it can source scripts/lib/*.sh).
# CONTROLD_REPO="/Users/YOU/dev/personal-config"

# Control D Profile IDs
# Retrieve these from your Control D Dashboard (Resolvers section)
# They are typically found in the resolver URL or settings.

# Privacy Profile ID
CTR_PROFILE_PRIVACY_ID="your_privacy_id_here"

# Gaming Profile ID
CTR_PROFILE_GAMING_ID="your_gaming_id_here"

# Browsing Profile ID
CTR_PROFILE_BROWSING_ID="your_browsing_id_here"
